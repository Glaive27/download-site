# 文件下载中心环境变量配置

# JWT 签名密钥（用于签发登录 Token）
# 必须设置为足够长的随机字符串，线上部署时务必修改
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-characters

# 预设管理员账号
ADMIN_USERNAME=Glaive

# 预设管理员密码
# 线上部署时务必修改为强密码
ADMIN_PASSWORD=19866179818

# 数据库 URL
# Render 部署时会自动注入 DATABASE_URL，本地开发留空则使用 SQLite
DATABASE_URL=

# Cloudflare R2（S3 API）配置
# 在 Render 控制台或 render.yaml 中设置，本地开发如需测试上传/下载也需配置
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET=your-r2-bucket-name

# R2 公开访问域名（可选）
# 如果桶已开启公开访问并绑定了自定义域名，可配置此项以使用直链而非预签名链接
R2_PUBLIC_URL=
